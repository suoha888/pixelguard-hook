# X Layer RPCs
XLAYER_MAINNET_RPC=https://rpc.xlayer.tech
XLAYER_TESTNET_RPC=https://testrpc.xlayer.tech/terigon

# Wallet. Prefer a Foundry keystore/account for final deployment if possible.
# PRIVATE_KEY=

# OKLink API key for verification.
# OKLINK_API_KEY=

# X Layer Uniswap v4 infrastructure.
# Mainnet defaults are known from Uniswap docs.
# If using X Layer testnet or a custom v4 deployment, set all relevant addresses explicitly.
V4_POOL_MANAGER=0x360e68faccca8ca495c1b759fd9eee466db9fb32
V4_POSITION_MANAGER=0xcf1eafc6928dc385a342e7c6491d371d2871458b

# This project uses Hookmate's simple V4 router for demo swaps.
# Deploy it with script/00_DeployHookmateRouter.s.sol, then paste the printed address here.
# V4_SWAP_ROUTER=

# Pool tokens. Defaults in scripts are local Anvil template tokens, so set these for X Layer.
# X Layer mainnet examples from OKX docs:
# WOKB  0xe538905cf8410324e03A5A23C1c177a474D59b2b
# WETH  0x5A77f1443D16ee5761d310e38b62f77f726bC71c
# USDT  0x1E4a5963aBFD975d8c9021ce480b42188849D41d
# TOKEN0=
# TOKEN1=

# Filled after script/00_DeployHook.s.sol succeeds.
# HOOK_ADDRESS=

# Demo swap size. Use 5000000000000000000 or larger to trigger GuardedSwap.
SWAP_AMOUNT=1000000000000000000
